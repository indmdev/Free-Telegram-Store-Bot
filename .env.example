# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_user_id_here
ADMIN_TELEGRAM_USERNAME=your_username_here

# Database Configuration
DATABASE_URL=sqlite:///bot_database.db

# Crypto Payment Configuration
CRYPTO_BOT_API_KEY=your_api_key_here

# Telegram Payments (Card) Configuration
TELEGRAM_PROVIDER_TOKEN=your_api_key_here

# Currency the card invoice is charged in (must be USD-denominated to match wallet amounts).
PAYMENT_CURRENCY=USD
