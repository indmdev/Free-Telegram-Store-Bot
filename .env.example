# ──────────────────────────────────────────────
#  Digital Products Store — Environment Variables
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Telegram Bot Settings ─────────────────────
# Required: Bot token from @BotFather
BOT_TOKEN=

# Required: Your numeric Telegram ID (e.g. 123456789)
ADMIN_TELEGRAM_ID=

# Optional: Your username without @ (used in some messages)
ADMIN_TELEGRAM_USERNAME=

# ── Database Settings ─────────────────────────
# Optional: Defaults to sqlite:///bot_database.db
# Example PostgreSQL: postgresql://user:password@localhost:5432/storebot
DATABASE_URL=sqlite:///bot_database.db

# ── Crypto Payment (CryptoBot) ────────────────
# Optional: Crypto Pay API token from @CryptoBot
# Blank = crypto top-up disabled
CRYPTO_BOT_API_KEY=

# ── Telegram Payments (Card) ──────────────────
# Optional: Provider token from @BotFather → Payments
# Blank = card top-up disabled
TELEGRAM_PROVIDER_TOKEN=

# Optional: Currency for card invoices (default: USD)
# Must be USD-denominated for wallet amounts to match
PAYMENT_CURRENCY=USD
